{
    "name": "candycore/sugar-charts",
    "description": "PHP port of NimbleMarkets/ntcharts — terminal charts (canvas, sparkline, bar, line, heatmap, scatter, time-series, OHLC, streamline, waveline) for CandyCore.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui", "terminal", "charts", "graphs",
        "sparkline", "bar-chart", "line-chart", "heatmap",
        "scatter", "time-series", "ohlc", "candlestick",
        "ntcharts", "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-charts",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-charts/issues",
        "source": "https://github.com/sugarcraft/sugar-charts",
        "docs":   "https://sugarcraft.github.io/lib/sugar-charts.html"
    },
    "require": {
        "php": "^8.1",
        "candycore/candy-core":      "@dev",
        "candycore/candy-sprinkles": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Charts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Charts\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
