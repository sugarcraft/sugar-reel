{
    "name": "sugarcraft/sugar-dash",
    "description": "Dashboard TUI library \u2014 column grid, constraint layout, ratio grid, data grid, tree, modal, status bar, tabs, plot/canvas, and module/plugin system. Ports patterns from bubble-grid, bubbletea-tilelayout, go-tealeaves, bubbleboxer, lattice, Homedash, and termui.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "dashboard",
        "layout",
        "grid",
        "panel",
        "table",
        "tree",
        "modal",
        "tabs",
        "plot",
        "chart",
        "status-bar",
        "bubbletea",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-dash",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-dash/issues",
        "source": "https://github.com/sugarcraft/sugar-dash"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Dash\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Dash\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
