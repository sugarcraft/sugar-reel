{
    "name": "candycore/candy-freeze",
    "description": "PHP port of charmbracelet/freeze — render code or terminal output to SVG screenshots with macOS-style window controls, drop shadow, line numbers, and inline ANSI SGR colour parsing.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "screenshot", "svg", "code", "terminal",
        "freeze", "ansi",
        "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/candy-freeze",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-freeze/issues",
        "source": "https://github.com/sugarcraft/candy-freeze",
        "docs":   "https://sugarcraft.github.io/lib/candy-freeze.html"
    },
    "require": {
        "php": "^8.1",
        "candycore/candy-core":      "@dev",
        "candycore/candy-sprinkles": "@dev",
        "candycore/candy-shine":     "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } },
        { "type": "path", "url": "../candy-shine",     "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Freeze\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Freeze\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/candyfreeze"],
    "minimum-stability": "dev",
    "prefer-stable": true
}
