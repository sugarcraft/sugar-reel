{
    "name": "candycore/candy-mold",
    "description": "Skeleton repo for bootstrapping a CandyCore TUI app — `composer create-project candycore/candy-mold my-app`. Ships a runnable counter Model wired through Program, plus a docs-as-code walkthrough that maps every file to the concept it demonstrates.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "candycore",
        "mold",
        "template",
        "skeleton",
        "starter",
        "bootstrap",
        "tui",
        "create-project"
    ],
    "homepage": "https://github.com/sugarcraft/candy-mold",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-mold/issues",
        "source": "https://github.com/sugarcraft/candy-mold",
        "docs":   "https://sugarcraft.github.io/lib/candy-mold.html"
    },
    "bin": ["bin/start"],
    "require": {
        "php": ">=8.1",
        "candycore/candy-core": "@dev",
        "candycore/candy-sprinkles": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
