#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * SugarPost CLI — send email from the terminal.
 *
 * Usage:
 *   pop --from <addr> --to <addr> [--subject "Subject"] [--attach <file>]
 *   pop < message.txt   (reads body from stdin; --from/--to required via flags or env)
 *
 * Env: RESEND_API_KEY, POP_FROM, POP_SMTP_HOST/PORT/USERNAME/PASSWORD, POP_SIGNATURE
 */
namespace CandyCore\Post;

require __DIR__ . '/../vendor/autoload.php';

use CandyCore\Post\{Email, Mailer, ResendTransport, SmtpTransport};

// Parse arguments manually (no getopt dependence on platform)
$args = parseArgs($argv);
$bin  = basename($argv[0]);

if ($args['help'] || ($argc = \count($args['positional'])) === 0 && !isset($args['opts']['from'])) {
    fwrite(STDOUT, help($bin));
    exit(0);
}

// Read body from STDIN if available and no --body given
$body = $args['opts']['body'] ?? '';
if ($body === '' && !\feof(STDIN)) {
    while (!\feof(STDIN)) {
        $body .= \fgets(STDIN);
    }
    $body = \trim($body);
}

// Build email
try {
    $email = buildEmail($args['opts'], $body);
} catch (\Throwable $e) {
    fwrite(STDERR, "Error: {$e->getMessage()}\n");
    exit(1);
}

// Choose transport
try {
    $transport = buildTransport();
} catch (\Throwable $e) {
    fwrite(STDERR, "Transport error: {$e->getMessage()}\n");
    exit(1);
}

$mailer = new Mailer($transport);

try {
    $mailer->send($email);
    echo "✓ Email sent via {$mailer->transportName()}.\n";
} catch (\Throwable $e) {
    fwrite(STDERR, "Send failed: {$e->getMessage()}\n");
    exit(1);
}

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function parseArgs(array $argv): array
{
    $positional = [];
    $opts = [];

    $i = 1;
    while ($i < \count($argv)) {
        $arg = $argv[$i];

        if ($arg === '--') {
            // End of options
            while (++$i < \count($argv)) {
                $positional[] = $argv[$i];
            }
        } elseif ($arg === '--from' || $arg === '-f') {
            $opts['from'] = $argv[++$i] ?? '';
        } elseif ($arg === '--to' || $arg === '-t') {
            $opts['to'][] = $argv[++$i] ?? '';
        } elseif ($arg === '--cc') {
            $opts['cc'][] = $argv[++$i] ?? '';
        } elseif ($arg === '--bcc') {
            $opts['bcc'][] = $argv[++$i] ?? '';
        } elseif ($arg === '--subject' || $arg === '-s') {
            $opts['subject'] = $argv[++$i] ?? '';
        } elseif ($arg === '--body') {
            $opts['body'] = $argv[++$i] ?? '';
        } elseif ($arg === '--attach' || $arg === '-a') {
            $opts['attachments'][] = $argv[++$i] ?? '';
        } elseif ($arg === '--reply-to') {
            $opts['reply_to'] = $argv[++$i] ?? '';
        } elseif ($arg === '--html') {
            $opts['html'] = $argv[++$i] ?? '';
        } elseif ($arg === '--help' || $arg === '-h') {
            $opts['help'] = true;
        } elseif (\str_starts_with($arg, '--')) {
            // Long flag with =
            if (($pos = \strpos($arg, '=')) !== false) {
                $key = \substr($arg, 2);
                $opts[$key] = \substr($arg, $pos + 1);
            }
        } elseif (\str_starts_with($arg, '-') && \strlen($arg) === 2) {
            // Short combined: -ft user@x.com recipient@x.com
            $flags = \str_split(\substr($arg, 1));
            foreach ($flags as $flag) {
                $opts['flag'][] = $flag;
            }
        } else {
            $positional[] = $arg;
        }
        $i++;
    }

    // Fill 'to' from positional if not set
    if (!isset($opts['to']) && $positional !== []) {
        $opts['to'] = $positional;
    }

    return ['positional' => $positional, 'opts' => $opts];
}

function buildEmail(array $opts, string $stdinBody): Email
{
    $from = $opts['from'] ?? \getenv('POP_FROM') ?: 'unknown@localhost';
    $to   = $opts['to'] ?? [];

    if ($to === []) {
        throw new \InvalidArgumentException('No --to recipient specified');
    }

    $body = $stdinBody !== '' ? $stdinBody : ($opts['body'] ?? null);
    $signature = \getenv('POP_SIGNATURE') ?: null;

    $email = new Email(
        from:    [$from],
        to:      $to,
        subject: $opts['subject'] ?? '(no subject)',
        body:    $body,
        cc:      $opts['cc'] ?? [],
        bcc:     $opts['bcc'] ?? [],
        htmlBody: $opts['html'] ?? null,
        replyTo: $opts['reply_to'] ?? null,
    );

    if ($signature !== null && $signature !== '') {
        $email = $email->withSignature($signature);
    }

    foreach ($opts['attachments'] ?? [] as $file) {
        if (!\file_exists($file)) {
            throw new \InvalidArgumentException("Attachment file not found: {$file}");
        }
        $email = $email->withAttachment(\basename($file), $file);
    }

    return $email;
}

function buildTransport(): Transport
{
    if (($apiKey = \getenv('RESEND_API_KEY')) !== false && $apiKey !== '') {
        return new ResendTransport($apiKey);
    }

    $host = \getenv('POP_SMTP_HOST') ?: '';
    if ($host !== '') {
        return new SmtpTransport(
            host:     $host,
            port:     (int) (\getenv('POP_SMTP_PORT') ?: 587),
            username: \getenv('POP_SMTP_USERNAME') ?: '',
            password: \getenv('POP_SMTP_PASSWORD') ?: '',
        );
    }

    throw new \RuntimeException(
        'No transport configured. Set RESEND_API_KEY or POP_SMTP_HOST environment variable.'
    );
}

function help(string $bin): string
{
    return <<<HELP
SugarPost CLI — send email from your terminal.

Usage:
  {$bin} --from <addr> --to <addr> [--subject "s"] [--body "text"]
  {$bin} --from <addr> --to <addr> --attach file.pdf < message.txt
  cat message.txt | {$bin} --from <addr> --to <addr>

  (body is read from STDIN if no --body flag is given)

Options:
  --from <addr>     Sender email address
  --to <addr>       Recipient email address (may be repeated)
  --cc <addr>       CC recipient (may be repeated)
  --bcc <addr>      BCC recipient (may be repeated)
  --subject <s>     Email subject
  --body <text>     Email body (else reads STDIN)
  --html <html>     HTML body alternative
  --attach <file>   Attach a file (may be repeated)
  --reply-to <addr> Reply-to address
  --help, -h        Show this help

Environment variables:
  RESEND_API_KEY          Resend API key (preferred)
  POP_SMTP_HOST/PORT/USER/PASS   SMTP credentials
  POP_FROM                Default sender address
  POP_SIGNATURE           Appended to email body

Examples:
  {$bin} --from me@example.com --to you@example.com --subject "Hello"
  POP_FROM=me@example.com cat message.txt | {$bin} --to you@example.com
  {$bin} --from me@example.com --to a@b.com --attach invoice.pdf --subject "Invoice"

HELP;
}
