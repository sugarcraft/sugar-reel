{
    "name": "candycore/honey-bounce",
    "description": "PHP port of charmbracelet/harmonica — damped spring physics + Newtonian projectile simulation for terminal animation.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "physics", "spring", "animation", "projectile",
        "tui", "terminal", "harmonica", "ryan-juckett",
        "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/honey-bounce",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/honey-bounce/issues",
        "source": "https://github.com/sugarcraft/honey-bounce",
        "docs":   "https://sugarcraft.github.io/lib/honey-bounce.html"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "CandyCore\\Bounce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Bounce\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
