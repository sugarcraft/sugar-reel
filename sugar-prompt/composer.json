{
    "name": "candycore/sugar-prompt",
    "description": "PHP port of charmbracelet/huh — interactive form library (Note, Input, Confirm, Select, MultiSelect, Text, FilePicker) with multi-page Group support and 6 stock themes.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui", "terminal", "cli",
        "form", "prompt", "input", "select",
        "multi-select", "confirm", "file-picker",
        "huh", "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-prompt",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-prompt/issues",
        "source": "https://github.com/sugarcraft/sugar-prompt",
        "docs":   "https://sugarcraft.github.io/lib/sugar-prompt.html"
    },
    "require": {
        "php": "^8.1",
        "candycore/candy-core":      "@dev",
        "candycore/candy-sprinkles": "@dev",
        "candycore/sugar-bits":      "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } },
        { "type": "path", "url": "../sugar-bits",      "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Prompt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Prompt\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
