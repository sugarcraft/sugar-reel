#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * CandyServe — Self-hostable Git Server
 *
 * Usage:
 *   soft-serve serve [--config path]   Start the server
 *   soft-serve init                     Initialize a new data directory
 *   soft-serve user add <username>     Add a user
 *   soft-serve user key <username> <keyfile>  Add an SSH key
 *   soft-serve repo list                List repos
 *   soft-serve repo create <name>      Create a repo
 *   soft-serve help                    Show this help
 */

namespace SugarCraft\Serve\Bin;

require __DIR__ . '/../vendor/autoload.php';

use SugarCraft\Serve\{AccessControl, Config, Repo, SSH\SSHServer, User};

const VERSION = '0.1.0';

function main(array $argv): int
{
    array_shift($argv);  // drop script name
    $command = $argv[0] ?? 'help';
    $args    = \array_slice($argv, 1);

    return match ($command) {
        'serve'  => cmdServe($args),
        'init'   => cmdInit($args),
        'user'   => cmdUser($args),
        'repo'   => cmdRepo($args),
        'help', '--help', '-h' => cmdHelp(),
        'version', '--version', '-v' => cmdVersion(),
        default  => cmdUnknown($command),
    };
}

// -------------------------------------------------------------------------
// Commands
// -------------------------------------------------------------------------

function cmdServe(array $args): int
{
    $configPath = null;
    foreach ($args as $i => $arg) {
        if ($arg === '--config' && isset($args[$i + 1])) {
            $configPath = $args[$i + 1];
        }
    }

    $config = $configPath !== null
        ? Config::load($configPath)
        : Config::fromDefaults();

    $ac = AccessControl::getInstance();

    echo "CandyServe v" . VERSION . "\n";
    echo "Data path:  {$config->dataPath}\n";
    echo "SSH:        {$config->sshListenAddr}\n";
    echo "HTTP:       {$config->httpListenAddr}\n";
    echo "Git daemon: {$config->gitListenAddr}\n";
    echo "\nStarting servers...\n";
    echo "(Full daemon mode requires the ssh2 extension and a running SSH daemon.)\n";
    echo "(Use 'soft-serve init' to initialize your data directory first.)\n\n";

    // List registered repos
    $dataPath = $config->dataPath;
    $reposPath = $dataPath . '/repositories';

    echo "Repositories:\n";
    if (\is_dir($reposPath)) {
        foreach (\scandir($reposPath) as $entry) {
            if ($entry === '.' || $entry === '..') continue;
            $repoPath = $reposPath . '/' . $entry;
            if (\is_dir($repoPath . '/.git')) {
                echo "  - {$entry}\n";
            }
        }
    }

    echo "\nNot yet running as daemon (daemon mode needs a process manager.)\n";
    echo "To serve Git over HTTP, point your web server to this script.\n";
    echo "For SSH access, use a reverse tunnel or configure sshd with ForceCommand.\n";

    return 0;
}

function cmdInit(array $args): int
{
    $dataPath = $args[0] ?? \getenv('CANDY_SERVE_DATA_PATH') ?: \sys_get_temp_dir() . '/candy-serve';

    if (\is_dir($dataPath) && \is_file($dataPath . '/config.yaml')) {
        echo "Already initialized: {$dataPath}\n";
        return 0;
    }

    echo "Initializing CandyServe data directory: {$dataPath}\n";

    // Create directories
    foreach (['repositories', 'ssh', 'hooks', 'tmp'] as $dir) {
        $path = "{$dataPath}/{$dir}";
        if (!\is_dir($path)) {
            \mkdir($path, 0755, true);
        }
    }

    // Create config
    $config = Config::fromDefaults();
    $configYaml = <<<YAML
name: "CandyServe"
ssh:
  listen_addr: ":23231"
  public_url: "ssh://localhost:23231"
  key_path: "ssh/soft_serve_host"
git:
  listen_addr: ":9418"
http:
  listen_addr: ":23232"
  public_url: "http://localhost:23232"
db:
  driver: "sqlite"
  data_source: "candy-serve.db"
lfs:
  enabled: true
YAML;

    \file_put_contents("{$dataPath}/config.yaml", $configYaml);

    echo "Done.\n";
    echo "Next steps:\n";
    echo "  1. Edit {$dataPath}/config.yaml\n";
    echo "  2. Generate SSH host key: ssh-keygen -t ed25519 -f {$dataPath}/ssh/soft_serve_host\n";
    echo "  3. Set CANDY_SERVE_INITIAL_ADMIN_KEYS=your-ssh-public-key\n";
    echo "  4. Run: soft-serve serve --config {$dataPath}/config.yaml\n";

    return 0;
}

function cmdUser(array $args): int
{
    $subcommand = $args[0] ?? 'help';
    $subargs    = \array_slice($args, 1);

    return match ($subcommand) {
        'add'    => cmdUserAdd($subargs),
        'key'    => cmdUserKey($subargs),
        'list'   => cmdUserList($subargs),
        'help'   => echo("Usage: soft-serve user add|key|list\n"),
        default  => cmdUnknown("user {$subcommand}"),
    };
}

function cmdUserAdd(array $args): int
{
    if (!isset($args[0])) {
        return error("Usage: soft-serve user add <username>\n");
    }

    $username = $args[0];
    $user = User::new($username)->withAdmin(true);

    echo "User '{$username}' created (admin: true)\n";
    echo "Use 'soft-serve user key {$username} < key.pub' to add an SSH public key.\n";

    return 0;
}

function cmdUserKey(array $args): int
{
    if (!isset($args[0]) || !isset($args[1])) {
        return error("Usage: soft-serve user key <username> [key-file]\n");
    }

    [$username, $keyFile] = $args;
    $key = $keyFile === '-' ? \stream_get_contents(\STDIN) : \file_get_contents($keyFile);

    if ($key === false || $key === '') {
        return error("Failed to read key from: {$keyFile}\n");
    }

    $user = User::new($username)->addAuthorizedKey(\trim($key));
    echo "Key added for user '{$username}'\n";
    echo "Authorized keys:\n";
    foreach ($user->authorizedKeysList() as $k) {
        echo "  " . \substr($k, 0, 60) . "...\n";
    }

    return 0;
}

function cmdUserList(array $args): int
{
    echo "Users:\n  (No users registered. Use 'soft-serve user add <username>')\n";
    return 0;
}

function cmdRepo(array $args): int
{
    $subcommand = $args[0] ?? 'help';
    $subargs    = \array_slice($args, 1);

    return match ($subcommand) {
        'list'   => cmdRepoList($subargs),
        'create' => cmdRepoCreate($subargs),
        'info'   => cmdRepoInfo($subargs),
        'help'   => echo("Usage: soft-serve repo list|create|info\n"),
        default  => cmdUnknown("repo {$subcommand}"),
    };
}

function cmdRepoList(array $args): int
{
    $dataPath = $args[0] ?? \getenv('CANDY_SERVE_DATA_PATH') ?: \sys_get_temp_dir() . '/candy-serve';
    $reposPath = $dataPath . '/repositories';

    if (!\is_dir($reposPath)) {
        echo "No repositories yet.\n";
        return 0;
    }

    echo "Repositories:\n";
    $found = false;

    foreach (\scandir($reposPath) as $entry) {
        if ($entry === '.' || $entry === '..') continue;
        $repoPath = $reposPath . '/' . $entry;
        if (!\is_dir($repoPath . '/.git')) continue;

        $found = true;
        $size  = \filesize($repoPath . '/.git/objects/pack/pack-' . \array_values(\array_filter(\scandir($repoPath . '/.git/objects/pack'), fn($f) => \str_starts_with($f, 'pack-')))[0] ?? 'N/A') ?? 0;

        echo "  {$entry}\n";
    }

    if (!$found) {
        echo "  (no repositories yet)\n";
    }

    return 0;
}

function cmdRepoCreate(array $args): int
{
    if (!isset($args[0])) {
        return error("Usage: soft-serve repo create <name>\n");
    }

    $dataPath = $args[1] ?? \getenv('CANDY_SERVE_DATA_PATH') ?: \sys_get_temp_dir() . '/candy-serve';
    $name     = $args[0];

    if (!\preg_match('/^[a-zA-Z0-9._-]+$/', $name)) {
        return error("Invalid repo name: {$name} (use only alphanumeric, dot, underscore, hyphen)\n");
    }

    $path = "{$dataPath}/repositories/{$name}";
    $repo = Repo::new($name, $path)->withPublic(true)->init();

    echo "Repository '{$name}' created at {$path}\n";
    echo "Clone URL: ssh://localhost:23231/{$name}\n";

    return 0;
}

function cmdRepoInfo(array $args): int
{
    if (!isset($args[0])) {
        return error("Usage: soft-serve repo info <name>\n");
    }

    $dataPath = $args[1] ?? \getenv('CANDY_SERVE_DATA_PATH') ?: \sys_get_temp_dir() . '/candy-serve';
    $name     = $args[0];
    $path     = "{$dataPath}/repositories/{$name}";

    if (!\is_dir($path . '/.git')) {
        return error("Repository not found: {$name}\n");
    }

    $repo = Repo::new($name, $path);

    echo "Name:         {$repo->name}\n";
    echo "Description:  {$repo->description ?: '(none)'}\n";
    echo "Public:       " . ($repo->isPublic ? 'yes' : 'no') . "\n";
    echo "Private:      " . ($repo->isPrivate() ? 'yes' : 'no') . "\n";
    echo "Allow push:   " . ($repo->allowPush ? 'yes' : 'no') . "\n";
    echo "Path:         {$repo->path()}\n";
    echo "Branches:     " . \implode(', ', $repo->branches()) . "\n";
    echo "Tags:         " . \implode(', ', $repo->tags()) . "\n";

    return 0;
}

function cmdHelp(): int
{
    echo <<<'HELP'
CandyServe — Self-hostable Git Server

Usage:
  soft-serve <command> [options]

Commands:
  serve [--config path]    Start the Git server
  init [data-path]         Initialize a new data directory
  user add <username>      Create a user
  user key <username> <file>  Add SSH public key for user (use - for stdin)
  user list                List users
  repo list [data-path]    List repositories
  repo create <name> [data-path]  Create a repository
  repo info <name> [data-path]    Show repository info
  help, --help, -h         Show this help
  version, --version, -v   Show version

Environment:
  CANDY_SERVE_DATA_PATH    Data directory (default: /tmp/candy-serve)

Examples:
  soft-serve init ~/candy-serve-data
  soft-serve serve --config ~/candy-serve-data/config.yaml
  soft-serve repo create my-project
  soft-serve user key alice ~/.ssh/id_ed25519.pub

HELP;
    return 0;
}

function cmdVersion(): int
{
    echo "CandyServe v" . VERSION . "\n";
    return 0;
}

// -------------------------------------------------------------------------
// Helpers
// -------------------------------------------------------------------------

function error(string $msg): int
{
    \fwrite(\STDERR, $msg);
    return 1;
}

function echo(string $msg): int
{
    echo $msg;
    return 0;
}

function cmdUnknown(string $cmd): int
{
    return error("Unknown command: {$cmd}\n  Run 'soft-serve help' for usage.\n");
}

// -------------------------------------------------------------------------
// Bootstrap
// -------------------------------------------------------------------------

\exit(main($argv));
