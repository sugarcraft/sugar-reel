{
    "name": "candycore/candy-shell",
    "description": "PHP port of charmbracelet/gum — composer-installable CLI of CandyCore TUI primitives. 13 subcommands: choose, confirm, file, filter, format, input, join, log, pager, spin, style, table, write.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui", "terminal", "cli", "shell",
        "gum", "prompt", "select", "confirm",
        "spinner", "filter", "style",
        "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/candy-shell",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-shell/issues",
        "source": "https://github.com/sugarcraft/candy-shell",
        "docs":   "https://sugarcraft.github.io/lib/candy-shell.html"
    },
    "bin": ["bin/candyshell"],
    "require": {
        "php": "^8.1",
        "candycore/candy-core":      "@dev",
        "candycore/candy-shine":     "@dev",
        "candycore/candy-sprinkles": "@dev",
        "candycore/sugar-bits":      "@dev",
        "candycore/sugar-prompt":    "@dev",
        "symfony/console":           "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-shine",     "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } },
        { "type": "path", "url": "../sugar-bits",      "options": { "symlink": true } },
        { "type": "path", "url": "../sugar-prompt",    "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Shell\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Shell\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
