{
    "name": "candycore/candy-gloss",
    "description": "PHP port of charmbracelet/lipgloss — declarative terminal styling and layout.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "candycore/candy-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Gloss\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Gloss\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
