{
    "name": "candycore/candy-kit",
    "description": "PHP port of charmbracelet/fang — opinionated CLI presentation helpers: StatusLine (✓/✗/⚠/ℹ), Banner, Section header, Stage step, HelpText page, and 6 stock themes (ansi/plain/charm/dracula/nord/catppuccin).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cli", "console", "presentation", "status-line",
        "banner", "help", "fang",
        "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/candy-kit",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-kit/issues",
        "source": "https://github.com/sugarcraft/candy-kit",
        "docs":   "https://sugarcraft.github.io/lib/candy-kit.html"
    },
    "require": {
        "php": "^8.1",
        "candycore/candy-core":      "@dev",
        "candycore/candy-sprinkles": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Kit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Kit\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
