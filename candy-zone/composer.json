{
    "name": "candycore/candy-zone",
    "description": "PHP port of lrstanley/bubblezone — mouse zone tracker for TUI apps.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui", "terminal", "cli",
        "mouse", "zones", "click",
        "bubblezone", "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/candy-zone",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-zone/issues",
        "source": "https://github.com/sugarcraft/candy-zone",
        "docs":   "https://sugarcraft.github.io/lib/candy-zone.html"
    },
    "require": {
        "php": "^8.1",
        "candycore/candy-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Zone\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Zone\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
