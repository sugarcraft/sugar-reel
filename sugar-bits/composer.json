{
    "name": "candycore/sugar-bits",
    "description": "PHP port of charmbracelet/bubbles — 14 pre-built TUI components (text input, list, table, viewport, file picker, progress, spinner, etc.) for CandyCore.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui", "terminal", "cli",
        "components", "widgets",
        "text-input", "textarea", "list", "table", "viewport",
        "file-picker", "progress-bar", "spinner",
        "bubbles", "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-bits",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-bits/issues",
        "source": "https://github.com/sugarcraft/sugar-bits",
        "docs":   "https://sugarcraft.github.io/lib/sugar-bits.html"
    },
    "require": {
        "php": "^8.1",
        "candycore/candy-core":  "@dev",
        "candycore/candy-sprinkles": "@dev",
        "candycore/honey-bounce": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",  "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } },
        { "type": "path", "url": "../honey-bounce", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Bits\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Bits\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
